{
    "statements-weights": {
        "while": 1,
        "assign": 1,
        "expression": 1,
        "if": 1,
        "print": 1,
        "scope": 1,
        "comment": 1,
        "semicolon": 1
    },
    "expressions-weights": {
        "binop": 1,
        "unop": 1,
        "print": 1,
        "in": 1,
        "variable": 1,
        "number": 1
    },
    "next-stmt-p": 0.9,
    "continue-expr-max-p": 0.6,
    "max-expression-depth": 3,
    "max-scope-depth": 4,
    "save-div": true,
    "save-while": true,
    "while-iterations-limit": 10
}
