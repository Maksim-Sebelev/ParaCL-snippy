{
    "statements-weights": {
        "while"      : 0,
        "assign"     : 0,
        "expression" : 0,
        "if"         : 0,
        "print"      : 1,
        "scope"      : 0,
        "comment"    : 0,
        "semicolon"  : 0
    },
    "expressions-weights": {
        "binop-weights": {
            "and"    : 0,
            "or"     : 0,
            "add"    : 0,
            "sub"    : 0,
            "mul"    : 0,
            "div"    : 1,
            "rem"    : 0,
            "asgn"   : 0,
            "addasgn": 0,
            "subasgn": 0,
            "divasgn": 0,
            "mulasgn": 0,
            "remasgn": 0,
            "iseq"   : 0,
            "isne"   : 0,
            "isab"   : 0,
            "isabe"  : 0,
            "isls"   : 0,
            "islse"  : 0
        },
        "unop-weights": {
            "minus": 0,
            "plus" : 0,
            "not"  : 0
        },
        "binop"   : 2,
        "unop"    : 0,
        "print"   : 0,
        "in"      : 1,
        "variable": 0,
        "number"  : 1
    },
    "next-stmt-p"           : 0.8,
    "continue-expr-max-p"   : 1,
    "max-expression-depth"  : 1,
    "max-scope-depth"       : 4,
    "save-div"              : true,
    "save-rem"              : true,
    "save-while"            : true,
    "while-iterations-limit": 30
}
