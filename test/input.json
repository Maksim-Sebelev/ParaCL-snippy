{
    "statements-weights": {
        "declaration": 1,
        "while": 1,
        "expression": 0,
        "if": 1,
        "print": 1,
        "scope": 1,
        "comment": 1,
        "semicolon": 0
    },
    "expressions-weights": {
        "binop": 1,
        "unop": 0,
        "print": 0,
        "in": 0,
        "variable": 1,
        "number": 9
    },
    "next-stmt-p": 0.8,
    "continue-expr-max-p": 0.6,
    "max-expression-depth": 3,
    "max-scope-depth": 4,
    "save-div": true,
    "save-while": true,
    "while-iterations-limit": 30
}
